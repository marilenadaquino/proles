    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/ParticipationWithPoliticalRole -->

    <owl:Class rdf:about="&proles;ParticipationWithPoliticalRole">
        <rdfs:label xml:lang="en">participation with political role</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/naryparticipation.owl#NaryParticipation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/prov#wasAttributedTo"/>
                <owl:onClass rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
                <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&proles;includesAgent"/>
                <owl:allValuesFrom rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&proles;participationIncludesPoliticalRoleInTime"/>
                <owl:allValuesFrom rdf:resource="&proles;PoliticalRoleInTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/prov#hadPrimarySource"/>
                <owl:allValuesFrom rdf:resource="&proles;Source"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A specific situation in which agents are involved in political relationships and participate in some event. Participation involves agents, political roles in time and other objects: it&apos;s restricted in a period of time, attested in a source and attributed to an editor of the assertion.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/Place -->

    <owl:Class rdf:about="&proles;Place">
        <rdfs:label xml:lang="en">place</rdfs:label>
        <rdfs:comment xml:lang="en">Places in which agents act with a political role.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/PoliticalRole -->

    <owl:Class rdf:about="&proles;PoliticalRole">
        <rdfs:label>political role</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.org/spar/pro/Role"/>
        <rdfs:comment xml:lang="en">Roles describing people&apos;s political relations, relationships among politicians and their political roles.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/PoliticalRoleInTime -->

    <owl:Class rdf:about="&proles;PoliticalRoleInTime">
        <rdfs:label xml:lang="en">political role in time</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.org/spar/pro/RoleInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/spar/pro/withRole"/>
                <owl:allValuesFrom rdf:resource="&proles;PoliticalRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/prov#hadPrimarySource"/>
                <owl:onClass rdf:resource="&proles;Source"/>
                <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/prov#wasAttributedTo"/>
                <owl:onClass rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
                <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A specific situation in which agents are involved in political relationships. All relations should be restricted in a period of time, attested in a source and attributed to an editor of the assertion.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/Source -->

    <owl:Class rdf:about="&proles;Source">
        <rdfs:label xml:lang="en">source</rdfs:label>
        <rdfs:comment xml:lang="en">Sources giving some information about people&apos;s roles and context of relations.</rdfs:comment>
    </owl:Class>
    



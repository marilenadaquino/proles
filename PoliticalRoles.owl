    <!-- http://www.essepuntato.it/2013/10/politicalroles/describesAgent -->

    <owl:ObjectProperty rdf:about="&proles;describesAgent">
        <rdfs:label xml:lang="en">describes agent</rdfs:label>
        <rdfs:comment xml:lang="en">A property relating a source to agents who are described in the source.</rdfs:comment>
        <rdfs:domain rdf:resource="&proles;Source"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="&proles;describesSituation"/>
            <rdf:Description rdf:about="http://purl.org/spar/pro/relatesToOrganization"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="&proles;describesSituation"/>
            <rdf:Description rdf:about="http://purl.org/spar/pro/isHeldBy"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="&proles;describesSituation"/>
            <rdf:Description rdf:about="&proles;includesAgent"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="&proles;describesSituation"/>
            <rdf:Description rdf:about="http://purl.org/spar/pro/relatesToPerson"/>
        </owl:propertyChainAxiom>
    </owl:ObjectProperty>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/describesSituation -->

    <owl:ObjectProperty rdf:about="&proles;describesSituation">
        <rdfs:label xml:lang="en">describes situation</rdfs:label>
        <rdfs:comment xml:lang="en">A property relating sources and situations described in that source.</rdfs:comment>
        <rdfs:domain rdf:resource="&proles;Source"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/situation.owl#Situation"/>
        <owl:inverseOf rdf:resource="http://www.w3.org/ns/prov#hadPrimarySource"/>
    </owl:ObjectProperty>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/hasRelatedAgent -->

    <owl:ObjectProperty rdf:about="&proles;hasRelatedAgent">
        <rdfs:label xml:lang="en">has related agent</rdfs:label>
        <rdfs:comment xml:lang="en">A property relating agents.</rdfs:comment>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.org/spar/pro/isRelatedToRoleInTime"/>
            <rdf:Description rdf:about="http://purl.org/spar/pro/isHeldBy"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="&proles;holdsPoliticalRoleInTime"/>
            <rdf:Description rdf:about="http://purl.org/spar/pro/relatesToPerson"/>
        </owl:propertyChainAxiom>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&proles;Place"/>
                    <rdf:Description rdf:about="http://xmlns.com/foaf/0.1/Agent"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://xmlns.com/foaf/0.1/Organization"/>
                    <rdf:Description rdf:about="http://xmlns.com/foaf/0.1/Person"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="&proles;holdsPoliticalRoleInTime"/>
            <rdf:Description rdf:about="http://purl.org/spar/pro/relatesToOrganization"/>
        </owl:propertyChainAxiom>
    </owl:ObjectProperty>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/hasRelatedSource -->

    <owl:ObjectProperty rdf:about="&proles;hasRelatedSource">
        <rdfs:label xml:lang="en">has related source</rdfs:label>
        <rdfs:comment xml:lang="en">A property relating agents and sources that attest some information about agents&apos; relations.</rdfs:comment>
        <rdfs:range rdf:resource="&proles;Source"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="&proles;holdsPoliticalRoleInTime"/>
            <rdf:Description rdf:about="http://www.w3.org/ns/prov#hadPrimarySource"/>
        </owl:propertyChainAxiom>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&proles;Place"/>
                    <rdf:Description rdf:about="http://xmlns.com/foaf/0.1/Agent"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.org/spar/pro/isRelatedToRoleInTime"/>
            <rdf:Description rdf:about="http://www.w3.org/ns/prov#hadPrimarySource"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="&proles;isIncludedInParticipationWithPoliticalRole"/>
            <rdf:Description rdf:about="http://www.w3.org/ns/prov#hadPrimarySource"/>
        </owl:propertyChainAxiom>
    </owl:ObjectProperty>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/holdsPoliticalRoleInTime -->

    <owl:ObjectProperty rdf:about="&proles;holdsPoliticalRoleInTime">
        <rdfs:label xml:lang="en">holds political role in time</rdfs:label>
        <rdfs:comment xml:lang="en">A property relating an agent to a situation that represents agents holding a political role or political relation in a period of time.</rdfs:comment>
        <rdfs:subPropertyOf rdf:resource="http://purl.org/spar/pro/holdsRoleInTime"/>
        <rdfs:range rdf:resource="&proles;PoliticalRoleInTime"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
    </owl:ObjectProperty>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/includesAgent -->

    <owl:ObjectProperty rdf:about="&proles;includesAgent">
        <rdfs:label>includes agent</rdfs:label>
        <rdfs:comment>A property relating a situation that describes a context for political relations and the agent involved with a political role.</rdfs:comment>
        <rdfs:domain rdf:resource="&proles;ParticipationWithPoliticalRole"/>
        <owl:inverseOf rdf:resource="&proles;isIncludedInParticipationWithPoliticalRole"/>
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/situation.owl#isSettingFor"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
    </owl:ObjectProperty>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/isIncludedInParticipationWithPoliticalRole -->

    <owl:ObjectProperty rdf:about="&proles;isIncludedInParticipationWithPoliticalRole">
        <rdfs:label>is included in participation with political role</rdfs:label>
        <rdfs:comment>A property relating an agent to a specific situation in which agent partecipates with a political role described in &apos;Political role in time&apos; class.

</rdfs:comment>
        <rdfs:range rdf:resource="&proles;ParticipationWithPoliticalRole"/>
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/naryparticipation.owl#isIncludedInParticipation"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
    </owl:ObjectProperty>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/isPlaceContextFor -->

    <owl:ObjectProperty rdf:about="&proles;isPlaceContextFor">
        <rdfs:label>is place context for</rdfs:label>
        <rdfs:comment>A property relating a place to the role for which that place provides the context.</rdfs:comment>
        <rdfs:subPropertyOf rdf:resource="http://purl.org/spar/pro/isRelatedToRoleInTime"/>
        <rdfs:domain rdf:resource="&proles;Place"/>
    </owl:ObjectProperty>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/isPoliticalRoleIn -->

    <owl:ObjectProperty rdf:about="&proles;isPoliticalRoleIn">
        <rdfs:label>is political role in</rdfs:label>
        <rdfs:comment>The property relating the definition of a specific political role to the time-indexed situation where an agent holds that role.</rdfs:comment>
        <rdfs:subPropertyOf rdf:resource="http://purl.org/spar/pro/isRoleIn"/>
        <rdfs:domain rdf:resource="&proles;PoliticalRole"/>
        <rdfs:range rdf:resource="&proles;PoliticalRoleInTime"/>
    </owl:ObjectProperty>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/participationIncludesPoliticalRoleInTime -->

    <owl:ObjectProperty rdf:about="&proles;participationIncludesPoliticalRoleInTime">
        <rdfs:label>participation includes political role in time</rdfs:label>
        <rdfs:comment>A property relating a situation that describes a context for political relations and a time-indexed situation representing political roles of agents&apos; involved in each situations.</rdfs:comment>
        <rdfs:domain rdf:resource="&proles;ParticipationWithPoliticalRole"/>
        <rdfs:range rdf:resource="&proles;PoliticalRoleInTime"/>
        <rdfs:subPropertyOf rdf:resource="&proles;participationIncludesRoleInTime"/>
    </owl:ObjectProperty>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/participationIncludesRoleInTime -->

    <owl:ObjectProperty rdf:about="&proles;participationIncludesRoleInTime">
        <rdfs:range rdf:resource="http://purl.org/spar/pro/RoleInTime"/>
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/naryparticipation.owl#NaryParticipation"/>
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/naryparticipation.owl#participationIncludes"/>
    </owl:ObjectProperty>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/relatesToPlace -->

    <owl:ObjectProperty rdf:about="&proles;relatesToPlace">
        <rdfs:label>relates to place</rdfs:label>
        <rdfs:comment>A property relating a time-indexed situation to a place that represents the context for that situation.</rdfs:comment>
        <rdfs:subPropertyOf rdf:resource="http://purl.org/spar/pro/relatesToEntity"/>
        <rdfs:range rdf:resource="&proles;Place"/>
        <owl:inverseOf rdf:resource="&proles;isPlaceContextFor"/>
    </owl:ObjectProperty>
    


    <!-- http://www.essepuntato.it/2013/10/politicalroles/withPoliticalRole -->

    <owl:ObjectProperty rdf:about="&proles;withPoliticalRole">
        <rdfs:label>with political role</rdfs:label>
        <rdfs:comment>A property relating a time-indexed situation to the political role held by an agent described in that situation.</rdfs:comment>
        <rdfs:subPropertyOf rdf:resource="http://purl.org/spar/pro/withRole"/>
        <rdfs:range rdf:resource="&proles;PoliticalRole"/>
        <rdfs:domain rdf:resource="&proles;PoliticalRoleInTime"/>
        <owl:inverseOf rdf:resource="&proles;isPoliticalRoleIn"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#hadPrimarySource -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#hadPrimarySource">
        <rdfs:label xml:lang="en">had primary source</rdfs:label>
        <rdfs:comment xml:lang="en">A property relating situations and the source that describes them.</rdfs:comment>
        <rdfs:range rdf:resource="&proles;Source"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/TR/prov-o/"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&proles;ParticipationWithPoliticalRole"/>
                    <rdf:Description rdf:about="&proles;PoliticalRoleInTime"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasAttributedTo -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasAttributedTo">
        <rdfs:comment>A property relating situations to an agent responsible for assertions about agents&apos; roles.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/TR/prov-o/"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&proles;ParticipationWithPoliticalRole"/>
                    <rdf:Description rdf:about="&proles;PoliticalRoleInTime"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
    </owl:ObjectProperty>
    


    <!-- 

    <rdf:Description rdf:about="http://www.ontologydesignpatterns.org/cp/owl/timeinterval.owl#TimeInterval">
        <rdfs:comment xml:lang="en">Any period of time in which events and relations are restricted.</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.ontologydesignpatterns.org/cp/owl/participation.owl#Event">
        <rdfs:comment xml:lang="en">Every sort of events in wich are involved agents with political role.</rdfs:comment>
